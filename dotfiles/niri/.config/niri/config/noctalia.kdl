binds {

    Alt+space hotkey-overlay-title="Toggle launcher" {spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "toggle";}
    Mod+Comma hotkey-overlay-title="Open Noctalia settings" { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "settings" "toggle"; }

    // Audio controls
    XF86AudioRaiseVolume allow-when-locked=true hotkey-overlay-title="Volume up" { spawn-sh "qs -c noctalia-shell ipc call volume increase"; }
    XF86AudioLowerVolume allow-when-locked=true hotkey-overlay-title="Volume down" { spawn-sh "qs -c noctalia-shell ipc call volume decrease"; }

    XF86AudioMute allow-when-locked=true hotkey-overlay-title="Mute audio" { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "volume" "muteOutput"; }
    XF86AudioMicMute allow-when-locked=true hotkey-overlay-title="Mute microphone" { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "volume" "muteInput"; }
 

    // Brightness controls
    XF86MonBrightnessUp allow-when-locked=true hotkey-overlay-title="Brightness up" { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "brightness" "increase"; }
    XF86MonBrightnessDown allow-when-locked=true hotkey-overlay-title="Brightness down" { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "brightness" "decrease"; }


    Mod+N hotkey-overlay-title="Toggle notification history" { spawn-sh "qs -c noctalia-shell ipc call notifications toggleHistory";}
    Mod+Alt+N hotkey-overlay-title="Toggle DND" { spawn-sh "qs -c noctalia-shell ipc call notifications toggleDND"; }
    Mod+Alt+W hotkey-overlay-title="Toggle wallpaper" { spawn-sh "qs -c noctalia-shell ipc call wallpaper toggle";}
    Mod+Escape hotkey-overlay-title="Lock screen" { spawn-sh "qs -c noctalia-shell ipc call lockScreen lock";}
    Mod+S hotkey-overlay-title="Toggle control center" { spawn-sh "qs -c noctalia-shell ipc call controlCenter toggle"; }
    Mod+V hotkey-overlay-title="Open clipboard" { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "clipboard"; }
    Mod+B hotkey-overlay-title="Toggle dock" { spawn-sh "qs -c noctalia-shell ipc call dock toggle"; }
    Mod+Period hotkey-overlay-title="Open emoji picker" { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "emoji"; }
    Mod+ALT+Period hotkey-overlay-title="Toggle kaomoji" { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "plugin:kaomoji" "toggle"; }
    Mod+Slash hotkey-overlay-title="Toggle keybind cheatsheet" { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "plugin:keybind-cheatsheet" "toggle"; }
    Mod+Ctrl+Alt+Shift+K hotkey-overlay-title="Toggle show keys" { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "plugin:show-keys" "toggle"; }
    Mod+Shift+N hotkey-overlay-title="Toggle sticky notes" { spawn-sh "qs -c noctalia-shell ipc call plugin:sticky-notes toggle"; }
    Mod+CTRL+SHIFT+S hotkey-overlay-title="Toggle screen toolkit" {spawn-sh "qs -c noctalia-shell ipc call plugin:screen-toolkit toggle"; }
    Mod+CTRL+SHIFT+C hotkey-overlay-title="Toggle system awake" {spawn-sh "~/.config/noctalia/plugins/keep-awake-plus/scripts/system-awake"; }
    Alt+F4 hotkey-overlay-title="Toggle session menu" { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "sessionMenu" "toggle"; }
    // Mod+C { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "calculator"; }
    // Mod+L { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "lockScreen" "lock"; }
}

spawn-at-startup "qs" "-c" "noctalia-shell"

// Set the overview wallpaper on the backdrop.
layer-rule {
  match namespace="^noctalia-overview*"
  place-within-backdrop true
}

